# PostgreSQL (Prisma). Ex.: Postgres na Prisma Data Platform / Neon / RDS.
# Nunca commite credenciais reais — copie para .env local.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Porta da API Express (padrão 3001). O Vite em dev faz proxy de /api para cá.
API_PORT=3002

# Opcional: base URL da API no front (produção). Em dev, deixe vazio para usar /api via proxy.
# VITE_API_BASE=

# Proxy do Vite para a API Express (em dev).
VITE_API_PROXY=http://127.0.0.1:3002

GEMINI_API_KEY=

APP_URL=http://localhost:3000
