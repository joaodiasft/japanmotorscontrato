# PostgreSQL (Prisma). Ex.: Neon, Supabase, Prisma Postgres.
# Em dev local: use URL direta quando possível; some "pooler" exige rede liberada na porta 5432.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&connect_timeout=60"

# API Express (npm run dev). Deve coincidir com VITE_API_PROXY.
API_PORT=3002

# Proxy do Vite: para onde /api/* encaminha no navegador
VITE_API_PROXY=http://127.0.0.1:3002

# Opcional
# GEMINI_API_KEY=
