{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/[...path].ts": {
      "includeFiles": "server/contrato-venda-template.html"
    },
    "api/settings/reset-templates.ts": {
      "includeFiles": "server/contrato-venda-template.html"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api\\/.*).*)",
      "destination": "/index.html"
    }
  ]
}

